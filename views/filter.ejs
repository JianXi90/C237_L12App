<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Filter by Rating and Keyword</title>
</head>

<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/navbar') %>
        <div class="container py-5">
            <h2 class="mb-4"> Filter Cool Songs</h2>
            <form method="GET" action="/filter" class="mb-4">
                <div class="row g-2">

                    <div class="col-md-4">
                        <input type="text" name="search" class="form-control" placeholder="Search artist or song...">
                    </div>

                    <div class="col-md-3">
                        <select name="genre" class="form-select">
                            <option value="">All Genres</option>

                            <% genres.forEach(g=> { %>
                                <option value="<%= g %>">
                                    <%= g %>
                                </option>
                                <% }) %>

                        </select>
                    </div>
                    <div class="col-md-3">
                        <select name="sort" class="form-select">
                            <option value="">Normal</option>
                            <option value="top">Most Voted</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary w-100">Filter</button>
                    </div>

                </div>

            </form>
            <div class="row">
                <% if (songs.length===0) { %>
                    <p>No songs found</p>
                    <% } %>
                        <% songs.forEach(song=> { %>
                            <div class="col-md-4 mb-4">
                                <div class="card shadow">
                                    <img src="<%= song.albumCoverUrl %>" class="card-img-top"
                                        style="height:200px; object-fit:cover;">
                                    <div class="card-body">
                                        <h5>
                                            <%= song.songTitle %>
                                        </h5>
                                        <p><b>Artist:</b>
                                            <%= song.artistName %>
                                        </p>
                                        <p><b>Genre:</b>
                                            <%= song.genre %>
                                        </p>
                                        <p>❤️ <%= song.votes || 0 %> votes</p>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
            </div>
        </div>
</body>

</html>