<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Edit Song</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('partials/navbar') %>

<div class="container py-5">
    <h2>Edit Song</h2>

    <form action="/update/<%= id %>" method="POST">

        <div class="mb-3">
            <label>Artist Name</label>
            <input type="text" name="artistName" class="form-control" 
                   value="<%= song.artistName %>">
        </div>

        <div class="mb-3">
            <label>Song Title</label>
            <input type="text" name="songTitle" class="form-control" 
                   value="<%= song.songTitle %>">
        </div>

        <div class="mb-3">
            <label>Genre</label>
            <input type="text" name="genre" class="form-control" 
                   value="<%= song.genre %>">
        </div>

        <div class="mb-3">
            <label>Description</label>
            <textarea name="description" class="form-control"><%= song.description %></textarea>
        </div>

        <div class="mb-3">
            <label>Album Cover URL</label>
            <input type="text" name="albumCoverUrl" class="form-control" 
                   value="<%= song.albumCoverUrl %>">
        </div>

        <div class="mb-3">
            <label>Preview URL</label>
            <input type="text" name="previewUrl" class="form-control" 
                   value="<%= song.previewUrl %>">
        </div>

        <button type="submit" class="btn btn-primary">
            Update Song
        </button>

        <a href="/listofsongs" class="btn btn-secondary">
            Cancel
        </a>

    </form>
</div>

</body>
</html>