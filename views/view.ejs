<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>View Song Detail</title>
</head>

<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/navbar') %>
        <div class="container py-5">
            <h2>🎵 View Song Details</h2>
            <p><b>Song Title:</b>
                <%= song.songTitle %>
            </p>
            <p><b>Artist Name:</b>
                <%= song.artistName %>
            </p>
            <p><b>Genre:</b>
                <%= song.genre %>
            </p>
            <p><b>Description:</b>
                <%= song.description ? song.description : "No description" %>
            </p>
            <p>
                <b>Album Cover:</b><br>
                <img src="<%= song.albumCoverUrl %>"
                    style="width:150px; height:150px; object-fit:cover; border-radius:10px;">
            </p>
            <p>
                <b>Preview:</b><br>
                <a href="<%= song.previewUrl %>" target="_blank" class="btn btn-success">
                    ▶ Play Preview
                </a>
            </p>
        </div>
        <button onclick="history.back()" class="btn btn-primary mt-3">
            Back
        </button>
        </div>

</body>

</html>