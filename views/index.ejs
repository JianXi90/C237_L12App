<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>MuseVote</title>
</head>

<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/navbar') %>
        <h1 class="text-center my-4">Vote Your Favorite Songs Today!</h1>
        <div class="text-center">
            <button class="btn btn-primary" onclick="location.href='/filter'">Browse Songs</button>
            <button class="btn btn-primary" onclick="location.href='/vote'">Start Voting</button>
        </div>
        <div class="text-center mt-4">
            <h2>Top 3 Trending Songs</h2>
            <a href="/rankings" class="btn btn-warning">
                View Rankings
            </a>
        </div>
        <div class="row">

            <% for(let i=0; i < topSongs.length; i++) { %>

                <div class="col-md-4 mb-4">

                    <div class="card shadow h-100">

                        <img src="<%= topSongs[i].albumCoverUrl %>" class="card-img-top"
                            style="height:250px; object-fit:cover;">

                        <div class="card-body text-center">

                            <% if(i===0) { %>
                                <h1>🥇</h1>
                                <% } else if(i===1) { %>
                                    <h1>🥈</h1>
                                    <% } else { %>
                                        <h1>🥉</h1>
                                        <% } %>

                                            <h4>
                                                <%= topSongs[i].song %>
                                            </h4>

                                            <p>
                                                <strong>
                                                    <%= topSongs[i].name %>
                                                </strong>
                                            </p>

                                            <p>
                                                <span class="badge bg-primary">
                                                    <%= topSongs[i].genre %>
                                                </span>
                                            </p>

                                            <h5>
                                                ❤️ <%= topSongs[i].votes || 0 %> Votes
                                            </h5>

                        </div>

                    </div>

                </div>

                <% } %>

        </div>

        </div>

        </div>
        <div class="text-center mt-4">
            <h2>Featured Genres</h2>
        </div>
        <div class="text-center mt-4">
            <h2>Songs Stats</h2>
            <p>Total Songs:</p>
            <p>Total Votes:</p>
        </div>
</body>

</html>