<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <title>Vote Songs</title>
</head>

<body>
    <%- include('partials/navbar') %>
<div class="container py-5">
    <h2 class="mb-4">Vote Your Favorite Songs</h2>
    <div class="row">
        <% let votedSongs = session.votedSongs || []; %>
        <% for(let i = 0; i < songs.length; i++) { %>
            <% let hasVoted = votedSongs.includes(i.toString()); %>
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm <%= hasVoted ? 'opacity-50' : '' %>">
                    <img src="<%= songs[i].albumCoverUrl %>" 
                         class="card-img-top"
                         style="height:200px; object-fit:cover;">
                    <div class="card-body">
                        <h5 class="card-title">
                            <%= songs[i].song %>
                        </h5>
                        <p>
                            <b>Artist:</b> <%= songs[i].name %>
                        </p>
                        <p>
                            <b>Genre:</b> <%= songs[i].genre %>
                        </p>
                        <p>
                            ❤️ Votes: <%= songs[i].votes || 0 %>
                        </p>
                        <% if (songs[i].previewUrl) { %>
                            <a href="<%= songs[i].previewUrl %>" target="_blank"
                               class="btn btn-success btn-sm w-100 mb-2">
                                ▶ Preview
                            </a>
                        <% } %>
                        <form action="/vote/<%= i %>" method="POST">
                            <button 
                                class="btn w-100 <%= hasVoted ? 'btn-secondary' : 'btn-danger' %>" 
                                <%= hasVoted ? 'disabled' : '' %>
                            >
                                <%= hasVoted ? 'Voted ✔' : 'Vote 👍' %>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</div>
</body>

</html>