<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>List of Songs</title>
</head>

<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/navbar') %>
        <div class="container mt-5">
            <h2 class="mb-4">List of Songs</h2>
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>No.</th>
                        <th>Artist Name</th>
                        <th>Song Title</th>
                        <th>Genre</th>
                        <th>Description</th>
                        <th>Preview</th>
                        <th>Album Cover</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <% for(let i=0; i < songs.length; i++) { %>
                        <tr>
                            <td>
                                <%= i + 1 %>
                            </td>
                            <td>
                                <%= songs[i].name %>
                            </td>
                            <td>
                                <%= songs[i].song %>
                            </td>
                            <td>
                                <%= songs[i].genre %>
                            </td>
                            <td>
                                <%= songs[i].description ? songs[i].description : "No description" %>
                            </td>
                            <td>
                                <a href="<%= songs[i].previewUrl %>" target="_blank" class="btn btn-sm btn-danger">
                                    ▶ Preview
                                </a>
                            </td>
                            <td>
                                <img src="<%= songs[i].albumCoverUrl %>" alt="cover"
                                    style="width:60px; height:60px; object-fit:cover; border-radius:8px;">
                                <br>
                                <%= songs[i].songTitle %>
                            </td>
                            <td>
                                <a href="/edit/<%= i %>" class="btn btn-sm btn-primary">Edit</a>

                                <form action="/delete/<%= i %>" method="POST" style="display:inline;">
                                    <button class="btn btn-sm btn-danger" onclick="return confirm('Delete this cool song?')">
                                        Delete
                                    </button>
                                </form>
                        </tr>
                        <% } %>
                </tbody>
            </table>

            <a href="/" class="btn btn-primary mt-3">Back</a>

        </div>
</body>

</html>