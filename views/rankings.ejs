<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Top Ranking of Songs</title>
</head>

<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/navbar') %>
        <div class="container py-5">
            <h1 class="text-center mb-5">Top Songs Leaderboard</h1>
            <div class="row">
                <% for(let i=0; i < rankedSongs.length; i++) { %>
                    <div class="col-md-4 mb-4">
                        <div class="card shadow h-100">
                            <img src="<%= rankedSongs[i].albumCoverUrl %>" class="card-img-top"
                                style="height:250px; object-fit:cover;">
                            <div class="card-body text-center">
                                <% if(i===0) { %>
                                    <h1>🥇</h1>
                                    <% } else if(i===1) { %>
                                        <h1>🥈</h1>
                                        <% } else if(i===2) { %>
                                            <h1>🥉</h1>
                                            <% } else { %>
                                                <h3>#<%= i + 1 %>
                                                </h3>
                                                <% } %>
                                                    <h4>
                                                        <%= rankedSongs[i].songTitle %>
                                                    </h4>
                                                    <p>
                                                        <strong>
                                                            <%= rankedSongs[i].artistName %>
                                                        </strong>
                                                    </p>
                                                    <span class="badge bg-primary">
                                                        <%= rankedSongs[i].genre %>
                                                    </span>
                                                    <hr>
                                                    <h5>❤️ <%= rankedSongs[i].votes || 0 %> Votes</h5>
                            </div>
                        </div>
                    </div>
                    <% } %>
            </div>
        </div>
</body>

</html>