<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Top Ranking of Songs</title>
</head>

<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/navbar') %>
        <div class="container py-5">
            <h2>Top Ranking of Songs</h2>
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Rank</th>
                        <th>Song</th>
                        <th>Artist</th>
                        <th>Genre</th>
                        <th>Votes</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(let i=0; i < rankedSongs.length; i++) { %>
                        <tr>
                            <td>
                                <% if(i===0) { %>
                                    🥇
                                    <% } else if(i===1) { %>
                                        🥈
                                        <% } else if(i===2) { %>
                                            🥉
                                            <% } else { %>
                                                <%= i + 1 %>
                                                    <% } %>
                            </td>
                            <td>
                                <%= rankedSongs[i].song %>
                            </td>
                            <td>
                                <%= rankedSongs[i].name %>
                            </td>
                            <td>
                                <%= rankedSongs[i].genre %>
                            </td>
                            <td>❤️ <%= rankedSongs[i].votes || 0 %>
                            </td>
                        </tr>
                        <% } %>
                </tbody>
            </table>
        </div>
</body>
</html>