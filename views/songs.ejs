<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Songs</title>
</head>

<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/navbar') %>
    <div class="container mt-3">
        <h2>Songs Entry Form</h2>
        <form action="/submit" method="post">
            <div class="mb-3 mt-3">
                <label for="name">Artist Name:</label>
                <input type="name" class="form-control" id="name" placeholder="Enter Name" name="name">
            </div>
            <div class="mb-3 mt-3">
                <label for="email">Song Title:</label>
                <input type="email" class="form-control" id="email" placeholder="Enter Song Title" name="email">
            </div>
            <!-- Activity 3: Edit contact.ejs to include more form fields – Contact No. and Comments: -->
            <div class="mb-3 mt-3">
                <label for="genre">Genre:</label>
                <input type="text" class="form-control" id="genre" placeholder="Enter Genre" name="genre">
            </div>
            <div class="mb-3 mt-3">
                <label for="description">Description:</label>
                <input type="text" class="form-control" id="description" placeholder="Enter Description" name="description">
            </div>
            <div class="mb-3 mt-3">
                <label for="link">Song Preview Link:</label>
                <input type="text" class="form-control" id="link" placeholder="Enter Preview Link" name="link">
            </div>
            <div class="mb-3 mt-3">
                <label for="image">Album Cover URL:</label>
                <input type="text" class="form-control" id="image" placeholder="Enter Album Cover URL" name="image">
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
    </div>
</body>

</html>