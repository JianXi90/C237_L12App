<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>List of Songs</title>
</head>

<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/header') %>
        <div class="container mt-5">
            <h2 class="mb-4">List of Songs</h2>
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>No.</th>
                        <th>Artist Name</th>
                        <th>Song Title</th>
                        <th>Genre</th>
                        <th>Description</th>
                    </tr>
                </thead>

                <tbody>
                    <% for(let i=0; i < cafes.length; i++) { %>
                        <tr>
                            <td>
                                <%= i + 1 %>
                            </td>
                            <td>
                                <%= cafes[i].Restaurant %>
                            </td>
                            <td>
                                <%= cafes[i].Food %>
                            </td>
                            <td>
                                <% let rating=Number(cafes[i].rating || 0); %>

                                    <% for(let r=1; r <=5; r++) { %>

                                        <% if(r <=rating) { %>
                                            <span style="color:gold;">★</span>
                                            <% } else { %>
                                                <span style="color:lightgray;">★</span>
                                                <% } %>

                                                    <% } %>
                            </td>
                            <td>
                                <% if(cafes[i].priority==="Must Get" ) { %>
                                    <span class="badge bg-warning text-dark">Must Get</span>
                                    <% } else if(cafes[i].priority==="Not So Often Get" ) { %>
                                        <span class="badge bg-success text-warning">Not So Often Get</span>
                                        <% } else { %>
                                            <span class="badge bg-danger">Rarely Get</span>
                                            <% } %>
                            </td>
                            <td>
                                <%= cafes[i].comments ? cafes[i].comments : "No comments" %>
                            </td>
                            <td>
                                <a href="/edit/<%= i %>" class="btn btn-sm btn-primary">
                                    Edit
                                </a>
                                <a href="/view/<%= i %>" class="btn btn-sm btn-info">
    View
</a>
                                <form action="/delete/<%= i %>" method="POST" style="display:inline;">
                                    <button onclick="return confirm('Are you sure you want to delete this column?')" type="submit"class="btn btn-sm btn-danger">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% } %>
                </tbody>
            </table>

            <a href="/" class="btn btn-primary mt-3">Back</a>

        </div>
</body>

</html>